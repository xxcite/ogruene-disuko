{
  "name": "disclosure-portal",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev:portal-local": "cd ./apps/portal &&  vite",
    "dev:portal-int": "cd ./apps/portal && vite --mode int",
    "typecheck": "cd ./apps/portal && vue-tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "cd ./apps/portal && vue-tsc --noEmit && vite build --mode $MODE",
    "build-ignore-errors": "cd ./apps/portal && VITE_COMMIT=$(git log --pretty=format:%h -n 1) vite build --mode $MODE",
    "preview:portal": "cd ./apps/portal && VITE_COMMIT=$(git log --pretty=format:%h -n 1) vite preview --port 3000",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:unknown-tags": "npx vue-auto-import-checker -c ./apps/portal/components.d.ts -p ./libs/ -f vuetify --imports-known -r -s",
    "check:unknown-tags:ci": "npx vue-auto-import-checker -c ./apps/portal/components.d.ts -p ./libs/ -f vuetify --imports-known -q",
    "playwright-install": "playwright install"
  },
  "dependencies": {
    "@date-io/dayjs": "3.2.0",
    "@mdi/font": "7.4.47",
    "@vavt/cm-extension": "1.10.1",
    "@vavt/v3-extension": "1.3.2",
    "@vueuse/components": "13.5.0",
    "@vueuse/core": "13.5.0",
    "axios": "1.18.0",
    "chart.js": "4.5.0",
    "clipboard": "2.0.11",
    "cropperjs": "1.6.2",
    "dayjs": "1.11.13",
    "dayjs-plugin-utc": "0.1.2",
    "dotenv": "17.2.0",
    "epic-spinners": "2.0.0",
    "lodash": "4.18.1",
    "mitt": "3.0.1",
    "pinia": "3.0.4",
    "sanitize-html": "2.17.0",
    "screenfull": "6.0.2",
    "unplugin-vue-markdown": "32.0.0",
    "v-code-diff": "1.13.1",
    "vue": "3.5.18",
    "vue-chartjs": "5.3.2",
    "vue-i18n": "9.14.5",
    "vue-json-viewer": "3.0.4",
    "vue-router": "4.5.1",
    "vue3-markdown-it": "1.0.10",
    "vuetify": "3.8.3"
  },
  "engines": {
    "node": "^24.15.0",
    "npm": "^11.12.1"
  },
  "devDependencies": {
    "@babel/types": "~7.28.0",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "~1.56.1",
    "@tailwindcss/vite": "~4.3.1",
    "@tsconfig/node22": "22.0.1",
    "@types/lodash": "~4.17.24",
    "@types/node": "~22.16.0",
    "@types/sanitize-html": "~2.16.0",
    "@vitejs/plugin-basic-ssl": "~2.3.0",
    "@vitejs/plugin-vue": "~6.0.4",
    "@vitest/ui": "^4.1.9",
    "@vue/compiler-sfc": "~3.5.13",
    "@vue/language-server": "~2.2.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "~0.7.0",
    "jsdom": "^27.2.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.58.0",
    "rollup-plugin-visualizer": "~5.14.0",
    "sass": "~1.89.0",
    "tailwindcss": "~4.3.1",
    "typescript": "~5.8.2",
    "unplugin-vue-components": "~0.26.0",
    "vite": "^8.1.0",
    "vite-plugin-oxlint": "~2.0.1",
    "vite-plugin-vue-devtools": "~8.0.7",
    "vite-plugin-vuetify": "~2.1.1",
    "vitest": "^4.1.9",
    "vue-auto-import-checker": "^1.1.0",
    "vue-tsc": "~2.2.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@rollup/rollup-linux-x64-musl": "^4.59.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.1",
    "lightningcss-linux-x64-musl": "^1.31.1"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": "oxlint"
  }
}
